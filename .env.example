# ── LLM Backend ──────────────────────────────────────────────────────────────
# "anthropic"    — use Anthropic native API (default)
# "openai_compat" — use any OpenAI-compatible endpoint (custom URL required)
# "openrouter"   — shortcut for OpenRouter (set OPENAI_COMPAT_API_KEY=sk-or-...)
# "local"        — shortcut for local vLLM at http://localhost:8000/v1
# "minimax"      — shortcut for Minimax (set MINIMAX_API_KEY=...)
# "codex"        — shortcut for OpenAI Codex (browser OAuth or OPENAI_COMPAT_API_KEY)
LLM_BACKEND=anthropic

# ── Anthropic native ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ccproxy / OAuth (Claude Pro/Max — no API key needed) ─────────────────────
# Option A: Full ccproxy setup
#   1. pip install 'eurekaclaw[oauth]'
#   2. ccproxy auth login claude_api
#   3. Set ANTHROPIC_AUTH_MODE=oauth (leave ANTHROPIC_API_KEY blank)
#
# Option B: Automatic fallback (if you're logged in to Claude Code)
#   Just leave ANTHROPIC_API_KEY blank — EurekaClaw reads ~/.claude/.credentials.json
#   automatically and uses your Claude Code OAuth token.
#
# ANTHROPIC_AUTH_MODE=oauth   # "api_key" (default) | "oauth"
# CCPROXY_PORT=8765            # port ccproxy listens on (default: 8765)

# ── OpenAI-compatible endpoint ────────────────────────────────────────────────
# Used when LLM_BACKEND=openai_compat (or the shortcuts openrouter / local).
#
# OpenRouter (LLM_BACKEND=openrouter):
#   OPENAI_COMPAT_API_KEY=sk-or-...
#   OPENAI_COMPAT_MODEL=meta-llama/llama-3.1-70b-instruct
#
# vLLM / local (LLM_BACKEND=local):
#   OPENAI_COMPAT_MODEL=Qwen/Qwen2.5-72B-Instruct
#   (base URL defaults to http://localhost:8000/v1)
#
# SGLang / other (LLM_BACKEND=openai_compat):
#   OPENAI_COMPAT_BASE_URL=http://localhost:30000/v1
#   OPENAI_COMPAT_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
#
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ── OpenAI / Codex ───────────────────────────────────────────────────────────
# Used when LLM_BACKEND=codex.
# Base URL is fixed to https://api.openai.com/v1.
#
# Option A: Codex CLI OAuth (Codex subscription — no API key needed)
#   1. pip install 'eurekaclaw[codex]'
#   2. npm install -g @openai/codex && codex auth login   # one-time browser login
#   3. eurekaclaw login --provider openai-codex           # imports Codex CLI token
#   4. Set CODEX_AUTH_MODE=oauth
#
# Option B: API key directly
#   Set OPENAI_COMPAT_API_KEY=sk-...
#
CODEX_AUTH_MODE=api_key   # "api_key" (default) | "oauth"
CODEX_MODEL=o4-mini

# ── Minimax ───────────────────────────────────────────────────────────────────
# Used when LLM_BACKEND=minimax.
# Base URL is fixed to https://api.minimaxi.chat/v1; only the key is needed.
# Available models: MiniMax-Text-01, abab6.5s-chat
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# Search APIs (optional — web search degrades gracefully without these)
BRAVE_SEARCH_API_KEY=
SERPAPI_KEY=

# Wolfram Alpha (optional — symbolic math)
WOLFRAM_APP_ID=

# Semantic Scholar (unauthenticated works, key unlocks higher rate limits)
S2_API_KEY=

# Learning loop mode: skills_only | rl | madmax
EUREKACLAW_MODE=skills_only

# Model to use for main agent reasoning
# claude-sonnet-4-6 (default, fast+cheap) | claude-opus-4-6 (deep reasoning, slower)
EUREKACLAW_MODEL=claude-sonnet-4-6

# Model to use for lightweight tasks (skill distillation, scoring)
EUREKACLAW_FAST_MODEL=claude-haiku-4-5-20251001

# Skills & memory persistence directories
EUREKACLAW_DIR=~/.eurekaclaw

# Max Theory Agent retry iterations
THEORY_MAX_ITERATIONS=10

# Theory proof pipeline: default | memory_guided
# default        — bottom-up literature-first proof pipeline
# memory_guided  — analysis-first pipeline that uses existing memory before proof planning
THEORY_PIPELINE=default

# ---- Token-efficiency knobs ------------------------------------------------
# Compress the agent loop's conversation history into a bullet-point summary
# every N tool-use turns (0 = disabled).  Default: 6.
CONTEXT_COMPRESS_AFTER_TURNS=6

# Auto-accept a proof without LLM peer-review when the prover's confidence
# meets or exceeds this threshold and no [GAP:...] flags are present. Higher
# values make verification more conservative. Default: 0.95.
AUTO_VERIFY_CONFIDENCE=0.95

# Minimum reviewer confidence required for a non-formal verification pass.
# Lean4/Coq proof checks can still pass independently of this threshold.
VERIFIER_PASS_CONFIDENCE=0.90

# Force conjecture refinement when the same lemma fails this many consecutive
# times with the same error pattern (stagnation detection). Default: 3.
STAGNATION_WINDOW=3

# Experiment stage mode: auto | true | false
# auto  — run only when the theorem contains measurable numerical bounds (default)
# true  — always run experiments regardless of theorem type
# false — always skip experiments (useful for structural/algebraic theory work)
EXPERIMENT_MODE=false
# ---- Token limits per call type --------------------------------------------
# Max tokens returned by the LLM for each type of call.
# Increase to allow longer outputs; decrease to save cost.
MAX_TOKENS_AGENT=8192        # main agent loop per reasoning turn
MAX_TOKENS_PROVER=4096       # proof generation
MAX_TOKENS_PLANNER=4096      # research direction planning (diverge)
MAX_TOKENS_DECOMPOSER=4096   # lemma decomposition
MAX_TOKENS_FORMALIZER=4096   # formalization, refiner, counterexample, resource analyst
MAX_TOKENS_VERIFIER=2048     # proof verification
MAX_TOKENS_CRYSTALLIZER=8192 # theorem statement crystallization
MAX_TOKENS_ASSEMBLER=8192    # proof assembly (assembler stage)
MAX_TOKENS_ARCHITECT=3000    # proof plan + skeleton (proof architect)
MAX_TOKENS_ANALYST=1600      # problem analysis stages
MAX_TOKENS_SKETCH=1024        # proof sketch generation
MAX_TOKENS_COMPRESS=1024      # context compression summaries (fast model)

# Gate mode: auto | human | none
# auto  — summary cards always shown; prompts only when confidence is low (default)
# human — summary cards + prompts at every stage boundary (allows text feedback)
# none  — fully silent, no cards, no prompts
GATE_MODE=auto

# Docker sandbox: true | false
USE_DOCKER_SANDBOX=false

# Lean4 binary path (optional)
LEAN4_BIN=lean

# LaTeX binary path (optional)
LATEX_BIN=pdflatex

# Output format for the generated paper: "latex" (default) or "markdown"
# latex   → produces paper.tex with full LaTeX preamble and theorem environments
# markdown → produces paper.md with YAML front-matter and $...$ / $$...$$ math
OUTPUT_FORMAT=latex

# ── LLM call tuning ──────────────────────────────────────────────────────────
# Max tokens per LLM response (lower = cheaper/faster; higher = more detailed output)
AGENT_MAX_TOKENS=4096

# Max tool-use turns per agent loop (each turn = 1 LLM call)
SURVEY_MAX_TURNS=8          # literature search: 8 is thorough, 4 is fast
THEORY_STAGE_MAX_TURNS=6    # per proof stage (formalize/decompose/prove/verify/…)
WRITER_MAX_TURNS=4          # paper generation

# Hard cap on arXiv results per search call (LLM cannot exceed this)
ARXIV_MAX_RESULTS=20

# Retry policy for LLM calls (handles rate limits and 5xx errors)
LLM_RETRY_ATTEMPTS=5        # number of attempts before giving up
LLM_RETRY_WAIT_MIN=4        # seconds — minimum wait between retries
LLM_RETRY_WAIT_MAX=90       # seconds — maximum wait (exponential backoff)
